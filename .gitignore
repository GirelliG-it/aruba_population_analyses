# --- Python Specific ---
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
.venv/
env/
venv/
.pytest_cache/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- Data & Outputs (Crucial for Data Analysis) ---
# Raw data is not being tracked because it can be large or sensitive
data/raw/*
# Directory structure is kept by allowing a .gitkeep file
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

# Databases
*.db
*.sqlite
*.sqlite3

# Ignore all generated figures and tables
outputs/figures/*
!outputs/figures/final_*.png
!outputs/figures/final_*.svg
!outputs/figures/.gitkeep
outputs/tables/*
!outputs/tables/final_*.csv
!outputs/tables/final_*.xlsx
!outputs/tables/final_*.md
!outputs/tables/.gitkeep

# --- OS Generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Office / Temp Files ---
.~lock.*
*.tmp
*.bak
