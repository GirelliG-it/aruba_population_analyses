# --- Python Specific ---
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
.venv/
env/
venv/
.pytest_cache/
tests/fixtures/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- Data & Outputs (Crucial for Data Analysis) ---
# Raw data is tracked so the pipeline is reproducible without refetching
# external sources.

data/processed/*
!data/processed/.gitkeep

# Ignore spreadsheet exports and Excel lock files under processed/external data
data/processed/**/*.xlsx
data/processed/**/*.csv
data/external/**/*.xlsx
data/external/**/*.csv

# Databases
*.db
*.sqlite
*.sqlite3

# Generated top-level figures
figures/*
!figures/final_*.png
!figures/final_*.svg
!figures/.gitkeep

# Ignore all generated figures and tables
outputs/figures/*
!outputs/figures/final_*.png
!outputs/figures/final_*.svg
!outputs/figures/.gitkeep
outputs/tables/*
!outputs/tables/final_*.csv
!outputs/tables/final_*.xlsx
!outputs/tables/final_*.md
!outputs/tables/.gitkeep

# --- OS Generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Office / Temp Files ---
.~lock.*
.env
*.tmp
*.bak
logs/*
!logs/.gitkeep
outputs/db_files/*
!outputs/db_files/.gitkeep
